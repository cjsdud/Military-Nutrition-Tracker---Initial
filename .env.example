DATABASE_URL=postgres://user:password@localhost:5432/military_nutrition
PORT=5000
NODE_ENV=development
# PGSSL=false  # 로컬 PostgreSQL에 SSL이 없으면 false

# 식약처 식품영양성분 OpenAPI 임포트 (npm run db:import)
# data.go.kr 에서 발급받은 "디코딩" 인증키
DATA_GO_KR_KEY=
# 이미 URL 인코딩된 키를 넣었다면 true
# DATA_GO_KR_KEY_ENCODED=true
# 'new'(기본, FoodNtrCpntDbInfo01) 또는 'i2790'
# FOOD_API_VARIANT=new
# 엔드포인트 직접 지정 시
# FOOD_API_BASE=https://apis.data.go.kr/1471000/FoodNtrCpntDbInfo01/getFoodNtrCpntDbInq01
